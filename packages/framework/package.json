{
	"name": "@sundayceo/framework",
	"version": "0.0.0",
	"type": "module",
	"license": "MIT",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./vite": {
			"types": "./dist/vite-plugin.d.ts",
			"import": "./dist/vite-plugin.js"
		},
		"./hono": {
			"types": "./dist/hono.d.ts",
			"import": "./dist/hono.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"check-types": "tsc --noEmit",
		"dev": "tsup --watch",
		"test": "vitest run"
	},
	"devDependencies": {
		"@sundayceo/typescript-config": "workspace:*",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"tsup": "catalog:",
		"typescript": "catalog:",
		"vite": "^8.0.13",
		"vitest": "catalog:"
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"vite": "^6.0.0 || ^7.0.0 || ^8.0.0",
		"hono": "^4.0.0"
	},
	"peerDependenciesMeta": {
		"vite": {
			"optional": true
		},
		"hono": {
			"optional": true
		}
	}
}
