		"react": "catalog:",
		"react-dom": "catalog:",
		"tsup": "catalog:",
		"typescript": "catalog:",
		"vite": "^8.0.13",
		"vitest": "catalog:"
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
	},
	"dependencies": {
		"@babel/generator": "^7.29.1",
		"@babel/parser": "^7.29.3",
		"@babel/traverse": "^7.29.0",
		"@babel/types": "^7.29.0"
	}
