{
	"name": "sundayceo-framework",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"check-types": "turbo run check-types",
		"test": "turbo run test",
		"prepare": "husky",
		"reset": "find . -type d \\( -name node_modules -o -name dist -o -name .turbo \\) -not -path './.git/*' -prune -exec rm -rf {} + && echo 'Cleaned. Run pnpm install to reinstall.'"
	},
	"devDependencies": {
		"@commitlint/cli": "catalog:",
		"@commitlint/config-conventional": "catalog:",
		"@eslint/js": "catalog:",
		"@ianvs/prettier-plugin-sort-imports": "catalog:",
		"eslint": "catalog:",
		"eslint-plugin-boundaries": "catalog:",
		"eslint-plugin-check-file": "catalog:",
		"globals": "catalog:",
		"husky": "catalog:",
		"prettier": "catalog:",
		"tsx": "catalog:",
		"turbo": "catalog:",
		"typescript": "catalog:",
		"typescript-eslint": "catalog:",
		"vitest": "catalog:"
	},
	"packageManager": "pnpm@10.33.4",
	"engines": {
		"node": ">=18"
	}
}
